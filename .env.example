# ================================
# Application
# ================================
APP_NAME="Registro de PI - IFMS"
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
SECRET_KEY=change-me-to-a-long-random-string-please-32chars-min
SESSION_COOKIE_NAME=rpi_session

# ================================
# Database (PostgreSQL)
# ================================
POSTGRES_USER=rpi
POSTGRES_PASSWORD=rpi_password
POSTGRES_DB=rpi
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://rpi:rpi_password@db:5432/rpi

# ================================
# Google OAuth
# ================================
# Crie credenciais em: https://console.cloud.google.com/apis/credentials
# Tipo: "OAuth client ID" -> "Web application"
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Lista de emails (separados por vírgula) que serão admins ao logar.
# Os demais entram com role "author".
ADMIN_EMAILS=admin@example.com

# ================================
# Email (Mailtrap por padrão)
# ================================
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=1da7eaff07312d
MAIL_PASSWORD=e0c9ba6af85b33
MAIL_FROM=no-reply@pi.local
MAIL_FROM_NAME="Registro de PI - IFMS"
MAIL_USE_TLS=true

# ================================
# Convites
# ================================
INVITATION_EXPIRES_HOURS=48

# ================================
# PDFs
# ================================
PDF_STORAGE_DIR=/app/storage/pdfs
